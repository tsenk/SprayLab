<UserControl
	x:Class="SprayLab.Gallery.GalleryView"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:gallery="using:SprayLab.Gallery">
	<Grid Background="{ThemeResource galleryBg}">
		<Grid.RowDefinitions>
			<RowDefinition Height="*" />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>

		<ScrollViewer Grid.Row="0" Padding="20,12">
			<ItemsControl x:Name="days">
				<ItemsControl.ItemTemplate>
					<DataTemplate x:DataType="gallery:DayGroup">
						<StackPanel>
							<Grid Margin="0,14,0,10">
								<CheckBox Content="Select all on this day" FontSize="12" MinWidth="0" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0,0,0" Tag="{x:Bind}" Click="onSelectDay" />
								<StackPanel HorizontalAlignment="Center" Width="140">
									<TextBlock Text="{x:Bind Title, Mode=OneWay}" FontSize="14" HorizontalAlignment="Center" />
									<Rectangle Height="1" Fill="{ThemeResource hairline}" Margin="0,6,0,0" />
								</StackPanel>
							</Grid>
							<GridView ItemsSource="{x:Bind Cards}" SelectionMode="None" IsItemClickEnabled="False" HorizontalAlignment="Center" />
						</StackPanel>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>
		</ScrollViewer>

		<Grid Grid.Row="1" Padding="24,12,24,18">
			<Button Content="Back" HorizontalAlignment="Left" Style="{StaticResource AccentButtonStyle}" Click="onBack" />
			<Button Content="Delete Selected" HorizontalAlignment="Right" Background="#E5383B" Foreground="White" Click="onDeleteSelected" />
		</Grid>
	</Grid>
</UserControl>
