<UserControl
	x:Class="SprayLab.Viewer.ViewerView"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:widgets="using:SprayLab.Widgets">
	<Grid Background="#111114">
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="300" />
			<ColumnDefinition Width="*" />
		</Grid.ColumnDefinitions>

		<Grid Grid.Column="0" Background="#1B1B1E" Padding="16">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto" />
				<RowDefinition Height="*" />
				<RowDefinition Height="Auto" />
			</Grid.RowDefinitions>

			<TextBlock Grid.Row="0" Text="Current Period Spray Average" FontSize="13" HorizontalAlignment="Center" Margin="0,6,0,12" />

			<Border Grid.Row="1" Background="#242427" CornerRadius="10">
				<widgets:SprayGraph x:Name="avgGraph" Margin="10" />
			</Border>

			<Grid Grid.Row="2" Margin="0,12,0,0">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="Auto" />
				</Grid.ColumnDefinitions>
				<TextBlock Grid.Column="0" Text="Latest Sprays for comparison" FontSize="12" VerticalAlignment="Center" />
				<NumberBox Grid.Column="1" x:Name="numRecent" Width="90" SpinButtonPlacementMode="Compact" Minimum="1" SmallChange="1" ValueChanged="onRecentChanged" />
			</Grid>
		</Grid>

		<Grid Grid.Column="1">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
				<RowDefinition Height="*" />
				<RowDefinition Height="Auto" />
			</Grid.RowDefinitions>

			<StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,14,0,0" Spacing="10">
				<TextBox x:Name="txtName" Width="320" FontSize="15" TextAlignment="Center" KeyDown="onNameKey" LostFocus="onNameCommit" />
				<Button Content="Delete" Style="{StaticResource AccentButtonStyle}" Click="onDelete" />
			</StackPanel>

			<StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0" Spacing="8">
				<TextBlock Text="Ignore mistake threshold (deg)" FontSize="12" VerticalAlignment="Center" />
				<NumberBox x:Name="numThresh" Width="90" SpinButtonPlacementMode="Compact" Minimum="0" SmallChange="0.1" />
				<Button Content="Apply" Style="{StaticResource AccentButtonStyle}" Click="onApply" />
			</StackPanel>

			<Grid Grid.Row="2" Margin="24,16">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto" />
					<ColumnDefinition Width="*" />
				</Grid.ColumnDefinitions>

				<Border Grid.Column="0" Background="#1D1D20" CornerRadius="12" Width="210" VerticalAlignment="Stretch">
					<widgets:MistakeList x:Name="mistakes" />
				</Border>

				<StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="24,0,0,0">
					<Border CornerRadius="12" Background="#1D1D20" Width="440" Height="460">
						<widgets:SprayGraph x:Name="graph" Margin="12" />
					</Border>
					<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="28" Margin="0,8,0,0">
						<TextBlock x:Name="txtDur" FontSize="13" />
						<TextBlock x:Name="txtBullets" FontSize="13" />
					</StackPanel>
				</StackPanel>
			</Grid>

			<StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="14" Margin="0,0,0,16">
				<Button Padding="8" Click="onPrev">
					<FontIcon Glyph="&#xE76B;" FontSize="13" />
				</Button>
				<Button Content="Back" Style="{StaticResource AccentButtonStyle}" Click="onBack" />
				<Button Padding="8" Click="onNext">
					<FontIcon Glyph="&#xE76C;" FontSize="13" />
				</Button>
			</StackPanel>
		</Grid>
	</Grid>
</UserControl>
