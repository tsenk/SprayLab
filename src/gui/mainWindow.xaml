<Window
	x:Class="SprayLab.MainWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:main="using:SprayLab.Main"
	xmlns:gallery="using:SprayLab.Gallery"
	xmlns:viewer="using:SprayLab.Viewer"
	Title="SprayLab">
	<Grid x:Name="root">
		<main:MainView x:Name="mainView" />
		<gallery:GalleryView x:Name="galleryView" Visibility="Collapsed" />
		<viewer:ViewerView x:Name="viewerView" Visibility="Collapsed" />
		<Button x:Name="btnTheme" Width="36" Height="36" CornerRadius="18" Padding="0" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,10,14,0" Click="onTheme">
			<FontIcon x:Name="iconTheme" Glyph="&#xE706;" FontSize="14" />
		</Button>
	</Grid>
</Window>
