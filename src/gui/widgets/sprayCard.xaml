<UserControl
	x:Class="SprayLab.Widgets.SprayCard"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
	<Border CornerRadius="10" Background="{ThemeResource cardBg}" Width="168" Padding="8" Margin="6" PointerPressed="onBody">
		<StackPanel>
			<Border CornerRadius="8" Background="{ThemeResource insetBg}" Height="168">
				<Image x:Name="thumb" Stretch="None" HorizontalAlignment="Center" VerticalAlignment="Center" />
			</Border>
			<TextBox x:Name="txtName" FontSize="11" Margin="0,5,0,5" BorderThickness="0" Background="Transparent" TextAlignment="Center" KeyDown="onNameKey" LostFocus="onNameCommit" />
			<Grid>
				<CheckBox x:Name="chk" MinWidth="0" Padding="0" HorizontalAlignment="Left" VerticalAlignment="Center" />
				<Button Content="Open" FontSize="12" HorizontalAlignment="Center" Padding="14,3" Style="{StaticResource AccentButtonStyle}" Click="onOpen" />
				<Button HorizontalAlignment="Right" Padding="5" Click="onDelete">
					<FontIcon Glyph="&#xE74D;" FontSize="12" />
				</Button>
			</Grid>
		</StackPanel>
	</Border>
</UserControl>
