<UserControl
	x:Class="SprayLab.Widgets.SprayCard"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
	<Border CornerRadius="10" Background="#1D1D20" Width="152" Padding="8" Margin="6">
		<StackPanel>
			<Border CornerRadius="8" Background="#242427" Height="168">
				<Image x:Name="thumb" Stretch="None" HorizontalAlignment="Center" VerticalAlignment="Center" />
			</Border>
			<TextBlock x:Name="txtName" FontSize="11" HorizontalAlignment="Center" Margin="0,7,0,7" TextTrimming="CharacterEllipsis" />
			<Button x:Name="btnOpen" Content="Open" FontSize="12" HorizontalAlignment="Center" Padding="14,3" Style="{StaticResource AccentButtonStyle}" Click="onOpen" />
		</StackPanel>
	</Border>
</UserControl>
